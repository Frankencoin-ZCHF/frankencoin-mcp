# Frankencoin MCP Server — Environment Variables

# Port (Railway sets this automatically)
PORT=3000

# Webhook persistence (Railway volume mount — set to /data)
WEBHOOK_DATA_DIR=/data

# CoinGecko Pro API key (optional — falls back to free tier)
COINGECKO_API_KEY=

# Rate limiting (requests per IP per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
RATE_LIMIT_WEBHOOK_MAX=10
