{
  "name": "frankencoin-mcp",
  "version": "1.1.0",
  "description": "MCP server for Frankencoin (ZCHF) protocol \u2014 real-time supply, positions, savings, FPS, challenges, analytics",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "frankencoin-mcp": "./dist/index.js",
    "frankencoin": "./src/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --watch src/index.js",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "lint": "eslint src/",
    "cli": "node src/cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "keywords": [
    "frankencoin",
    "zchf",
    "mcp",
    "defi",
    "stablecoin"
  ],
  "author": "Frankencoin Association",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Frankencoin-ZCHF/frankencoin-mcp"
  }
}
